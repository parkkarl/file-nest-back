# Server
PORT=3000
NODE_ENV=development

# Base URL used to build absolute links (Location headers, _links, share URLs)
PUBLIC_BASE_URL=http://localhost:3000

# Comma-separated list of allowed origins for CORS. "*" allowed only in development.
# In production, leave unset to default to PUBLIC_BASE_URL.
ALLOWED_ORIGINS=*

# JWT secret for owner endpoints. In production it must be set, >= 32 chars,
# and must not be the dev placeholder.
JWT_SECRET=dev-secret-change-me

# SQLite database path
DATABASE_URL=./data/file-nest.db

# Directory where binary file blobs are stored
STORAGE_DIR=./storage

# Max upload size in bytes (25 MB default)
MAX_UPLOAD_BYTES=26214400
